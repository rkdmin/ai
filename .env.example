# 백엔드 API URL (필수)
# 로컬:        http://localhost:8000
# 개발/테스트: Render URL
# 운영:        Railway URL
VITE_API_URL=http://localhost:8000

# 테스트 모드: true 로 설정하면 백엔드 호출 없이 더미 데이터를 반환합니다.
VITE_MOCK=

# 개발자 인스펙터: true 로 설정하면 화면 우하단에 🐞 버튼이 노출됩니다.
# Phase 2 부터는 AI 호출이 백엔드로 이동했으므로 패널에 표시되는 항목은 거의 없습니다.
# 출시 빌드에서는 미설정.
VITE_DEV_INSPECTOR=

# Supabase Auth OAuth 진입 URL (Phase 3)
# 예: https://xxxx.supabase.co
VITE_SUPABASE_URL=
