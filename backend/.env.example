# Gemini API key (필수)
GEMINI_API_KEY=

# CORS — 콤마 구분 (운영 도메인 추가 시 늘리기)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost,capacitor://localhost

# 서버 포트 (Render/Railway 는 PORT 환경변수 자동 주입)
PORT=8000

# 로컬 개발용 — true 면 rate limit 우회 (운영에는 절대 설정 금지)
RATE_LIMIT_DISABLED=false

# Phase 3 자리표시자 — Supabase 연동 시 사용
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
JWT_SECRET=
